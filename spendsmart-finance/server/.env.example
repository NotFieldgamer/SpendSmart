# SpendSmart API — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spendsmart?retryWrites=true&w=majority&appName=SpendSmart

# JWT — use `openssl rand -hex 32` to generate a strong secret
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS) — comma-separate multiple origins
# Development: http://localhost:5173
# Production:  https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
